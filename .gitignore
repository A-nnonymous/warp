runtime/local_config.yaml

# Runtime artifacts
runtime/control_plane.log
runtime/session_state*.json
runtime/generated_prompts/
runtime/generated_wrappers/
runtime/logs/

# Python
runtime/__pycache__/
runtime/cp/__pycache__/
