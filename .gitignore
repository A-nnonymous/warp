*.py[cod]

# Node / Frontend build deps
runtime/web/node_modules/

# Mutable state (runtime-generated, not source of truth)
state/agent_runtime.yaml
state/heartbeats.yaml
state/provider_stats.yaml
state/peek/

# Worktrees (large, machine-local)
worktrees/*
!worktrees/.gitkeep

# OS
.DS_Store
